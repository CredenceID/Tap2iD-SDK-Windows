<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Tap2iDSampleWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tap2iDSampleWinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d"
    >

    <Grid>
        <Grid.Resources>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        </Grid.Resources>
        <!-- Define Rows for Each Section -->
        <Grid.RowDefinitions>
            <!-- Top Section -->
            <RowDefinition Height="Auto"/>
            <!-- Logs Section -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Control Section -->
            <ColumnDefinition Width="Auto"/>
            <!-- Results Section -->
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Top StackPanel for License Validation, Camera Selection, Scan QR Code Button, and Clear Button -->
        <!-- LEFT COLUMN (Unchanged) -->
        <Grid Grid.Row="0" Grid.Column="0"
      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
      Margin="10,10,0,0" BorderBrush="#1E534B" BorderThickness="2"
      CornerRadius="9" Background="#D1E4E3">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Tap2iD SDK Windows" FontSize="32" FontFamily="Arial" FontWeight="Bold" Margin="20,10,0,10"/>

                <!-- Right Side Header Items -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,20,10">

                    <!-- Profile Badge -->
                    <Grid Background="#B3B3B3" CornerRadius="15" Margin="0,0,15,0">
                        <TextBlock x:Name="profileTextBlock" FontSize="16" Foreground="White" FontFamily="Arial" Margin="10,5,10,5"
                           Visibility="{Binding Text, ElementName=profileTextBlock, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>

                    <!-- Settings Button -->
                    <Button x:Name="SettingsButton" Click="SettingsButton_Click" 
                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Settings"
                    VerticalAlignment="Center">
                        <SymbolIcon Symbol="Setting" Foreground="#1E534B"/>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- Version -->
            <TextBlock Grid.Row="1" x:Name="VersionTextBlock" Text="Version" FontSize="16" FontFamily="Arial" Margin="20,0,0,10"/>

            <!-- Initialization -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputLicenseTextBox" Grid.Column="0" Width="380" BorderBrush="#1E534B"
                 PlaceholderText="Enter License Key or use License.txt" FontSize="16" CornerRadius="9" Margin="20,0,0,10" TextWrapping="Wrap"/>
                <Button x:Name="VerifyLicenseAndInitButton" Grid.Column="1" Content="Initialize SDK" Click="VerifyLicenseAndInitButton_Click" 
                Width="150" Height="80" Background="#1E534B" Foreground="White" FontSize="16" CornerRadius="9" Margin="10,0,0,10"/>
                <Button x:Name="Clear" Grid.Column="2" Content="Clear" Click="ClearButton_Click" 
                Width="150" Height="80" BorderThickness="2" BorderBrush="#1E534B" Background="White" Foreground="#1E534B" FontSize="16" CornerRadius="9" Margin="10,0,10,10"/>
            </Grid>

            <!-- Engagement Selection -->
            <TextBlock Grid.Row="3" Text="Select Device Engagement Method" FontSize="16" FontFamily="Arial" Margin="20,0,0,10"/>

            <Grid Grid.Row="4" Margin="20,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ActivateNfcButton" Grid.Column="0" Click="ActivateNfcButton_Click" Content="NFC Tap" 
                Width="150" Height="80" BorderThickness="2" BorderBrush="#1E534B" Background="#1E534B" Foreground="White" FontSize="16" CornerRadius="9" Margin="10,0,1,10"/>
                <Button x:Name="ActivateScanQrCodeButton" Grid.Column="1" Click="ActivateScanQrCodeButton_Click" Content="Scan Qr Code" 
                Width="150" Height="80" BorderThickness="2" BorderBrush="#1E534B" Background="#1E534B" Foreground="White" IsEnabled="False" FontSize="16" CornerRadius="9" Margin="1,0,10,10"/>
            </Grid>

            <Rectangle Grid.Row="5" Fill="#1E534B" Height="1" Margin="0,0,0,0"/>

            <TextBlock Grid.Row="6" x:Name="DeviceEngagementTitle" Text="Device Engagement" FontSize="16" FontFamily="Arial" Margin="20,10,0,10"/>

            <!-- Engagement Panels -->
            <StackPanel x:Name="NoCommandPannel" Grid.Row="7" Height="110"/>

            <StackPanel x:Name="CameraCommandsPanel" Grid.Row="7" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DeviceEngagementStringInputTextBox" Grid.Column="0" TextChanged="DeviceEngagementStringInputTextChangenHandler"
                     Width="380" Height="80" BorderBrush="#1E534B" PlaceholderText="Device Engagement Data..." FontSize="16" CornerRadius="9" Margin="20,0,0,30"/>
                    <Button x:Name="ClearEngagementStringButton" Grid.Column="1" Click="ClearEngagementStringButton_Click" Content="Clear"
                    Width="150" Height="80" BorderThickness="2" BorderBrush="#1E534B" Background="White" Foreground="#1E534B" FontSize="16" CornerRadius="9" Margin="10,0,0,30"/>
                    <Button x:Name="CameraButton" Grid.Column="2" Click="ScanQRCodeButton_Click" Width="150" Height="80" Background="#1E534B" CornerRadius="9" Margin="10,0,0,30">
                        <Image Source="/Assets/camwhiteico.png" Width="60" Height="60"/>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="NfcCommandsPanel" Grid.Row="7" Visibility="Collapsed">
                <Grid Margin="10,10,10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="ProgressPanel" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressRing x:Name="ProgressRing" Width="80" Height="80" IsActive="False" Foreground="Black"/>
                    </StackPanel>

                    <TextBlock x:Name="NfcReaderTextStatus" Grid.Column="1" Text="Reader is waiting..." FontSize="24" FontFamily="Arial" Margin="50,25,0,10"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- RIGHT COLUMN: RESULTS -->
        <!-- 1. ResultsGrid: This name allows C# to find the container -->
        <Grid x:Name="ResultsGrid"
      Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
      BorderBrush="#1E534B" BorderThickness="2" CornerRadius="9" Margin="10,10,10,10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Image -->
                <RowDefinition Height="Auto"/>
                <!-- Age Check -->
                <RowDefinition Height="*"/>
                <!-- Dynamic List -->
                <RowDefinition Height="Auto"/>
                <!-- Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Validation Checks -->
            </Grid.RowDefinitions>

            <!-- 2. Profile Image (No Binding, Manual Set) -->
            <Image x:Name="ProfileImage" 
           Width="200" Height="200" 
           Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,10"/>

            <!-- 3. Age Over 21 -->
            <Grid x:Name="AgeOver21TextBlockBackground" Grid.Row="1"
          BorderBrush="#1E534B" BorderThickness="0" CornerRadius="15"
          HorizontalAlignment="Center" Background="#B3B3B3" Visibility="Collapsed" Margin="0,0,0,10">
                <TextBlock x:Name="AgeOver21TextBlock" Text="Age Over 21+" FontSize="16" Foreground="White" FontFamily="Arial" Margin="15,5,15,5"/>
            </Grid>

            <!-- 4. SCALABLE RESULTS LIST (Text Data) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="20,5,20,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 5. Divider: This name allows C# to find it if needed -->
            <Rectangle x:Name="Divider"
               Grid.Row="3" Height="2" Fill="Black" Margin="5,10,5,10"/>

            <!-- 6. Validation Checks -->
            <Grid x:Name="ValidationGrid" Grid.Row="4" Margin="20,5,20,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title for Bottom Section -->
                <TextBlock Text="Validation Checks" FontWeight="Bold" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,10" 
            FontSize="18" Visibility="{Binding Text, ElementName=MSOCheckIcon, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- MSO Check -->
                <TextBlock Text="MSO Check:" FontWeight="Bold" Grid.Row="1" Grid.Column="0" Margin="0,5,5,5"
           Visibility="{Binding Text, ElementName=MSOCheckIcon, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock  x:Name="MSOCheckIcon" Grid.Row="1" Grid.Column="1"  FontSize="20" 
            Foreground="Green" 
            Visibility="{Binding Text, ElementName=MSOCheckIcon, Converter={StaticResource StringToVisibilityConverter}}"  Tag="clearable"/>

                <!-- MSO Signed -->
                <TextBlock Text="Device Signed:" FontWeight="Bold" Grid.Row="2" Grid.Column="0" Margin="0,5,5,5"
           Visibility="{Binding Text, ElementName=DeviceSignedIcon, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock  x:Name="DeviceSignedIcon" Grid.Row="2" Grid.Column="1"  FontSize="20" 
            Foreground="Green" 
            Visibility="{Binding Text, ElementName=DeviceSignedIcon, Converter={StaticResource StringToVisibilityConverter}}" Tag="clearable"/>

                <!-- IssuerSignedIcon -->
                <TextBlock Text="Issuer Signed:" FontWeight="Bold" Grid.Row="3" Grid.Column="0" Margin="0,5,5,5" 
           Visibility="{Binding Text, ElementName=IssuerSignedIcon, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock  x:Name="IssuerSignedIcon" Grid.Row="3" Grid.Column="1" FontSize="20" 
            Foreground="Green" 
            Visibility="{Binding Text, ElementName=IssuerSignedIcon, Converter={StaticResource StringToVisibilityConverter}}" Tag="clearable"/>

                <!-- Trusted Certificate Check -->
                <TextBlock Text="Trusted Certificate:" FontWeight="Bold" Grid.Row="4" Grid.Column="0" Margin="0,5,5,5"
           Visibility="{Binding Text, ElementName=TrustedCertificateIcon, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock  x:Name="TrustedCertificateIcon" Grid.Row="4" Grid.Column="1" FontSize="20"
            Foreground="Green"
            Visibility="{Binding Text, ElementName=TrustedCertificateIcon, Converter={StaticResource StringToVisibilityConverter}}" Tag="clearable"/>
            </Grid>
        </Grid>
        <!-- LOGS PANEL -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="10,10,0,10" BorderBrush="#1E534B" BorderThickness="2" CornerRadius="9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="Logs" FontSize="32" FontWeight="Bold" FontFamily="Arial" Margin="20,10,0,10"/>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button x:Name="CopyLogsButton" Content="Copy Logs" Click="CopyLogsButton_Click" Width="150" Height="40" Background="#1E534B" Foreground="White" FontSize="16" CornerRadius="9"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="1" Fill="#1E534B" Height="1"/>

            <ScrollViewer Grid.Row="2" x:Name="LogsScrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogsValueTextBlock" FontSize="16" MaxWidth="700" FontFamily="Arial" Margin="10,10,10,10" TextWrapping="Wrap"
                       Loaded="LogsValueTextBlock_Loaded" SizeChanged="LogsValueTextBlock_SizeChanged"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
